# SAP-EWM 机器人调度平台 .gitignore v3.4

# 凭证（绝对禁止入 Git）
secrets/
.env
.env.*
!/.env.example

# 数据库运行时
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# 日志
logs/
*.log
erl_crash.dump

# 备份
backup/
*.tar.gz
*.zip
*.tmp

# Node-RED 流程备份（自动导出，不纳入版本管理）
nodered/flows/backups/
nodered/flows/tab_*.json

# Docker 数据卷（named volume 数据由 Docker 管理）
nodered-data/

# Redis 运行时
dump.rdb
appendonly.aof

# Dify 运行时
dify-data/

# MQTT 运行时
mqtt-data/
mqtt/passwd
mqtt/passwd

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# 测试
test/
/tests/     # Only root-level, not subproject tests (e.g. sap-bridge/tests/)
__pycache__/
*.pyc
.pytest_cache/
*.coverage
coverage.xml

# 构建
node_modules/
dist/
build/

# Cursor MCP（如启用）
.cursor/mcp.json

# 临时技能目录
temp-skills/

# AI 工具配置（不纳入仓库版本管理）
.cursor/skills/
.qoder/
.workbuddy/

# 对话记录（自动生成的个人日志）
transcripts/
SESSION_STATUS.md

# Playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# Dashboard debug/temp files
dashboard/tmp_*.png
dashboard/dashboard_*_state.json
dashboard/debug_*.cjs
dashboard/explore_*.cjs
dashboard/test_login.cjs