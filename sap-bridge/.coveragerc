[run]
source = .
omit =
    # SAP NW RFC SDK required - cannot be tested in CI
    */backends/wm_backend.py
    # Hardware simulators
    */simulators/*
    # Test files
    */tests/*
    # Application entrypoint - wires all components, hard to unit test
    main.py

[report]
show_missing = true
skip_covered = false
exclude_lines =
    pragma: no cover
    def __repr__
    if __name__ == .__main__.:
