[run]
branch = true
source = .
omit =
    # SAP NW RFC SDK required - cannot be tested in CI
    */backends/wm_backend.py
    # Test files
    */tests/*

[report]
show_missing = true
skip_covered = false
exclude_lines =
    pragma: no cover
    def __repr__
    if __name__ == .__main__.:
    raise NotImplementedError
