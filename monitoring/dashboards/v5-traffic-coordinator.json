{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    }
  ],
  "title": "V5 Traffic Coordinator",
  "uid": "v5-traffic-coordinator",
  "schemaVersion": 39,
  "version": 2,
  "tags": ["v5", "traffic-coordinator", "ewm-robot"],
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "5s",
  "panels": [
    {
      "id": 1,
      "title": "Active Assignments",
      "type": "stat",
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green" },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "traffic_coordinator_active_assignments",
          "legendFormat": "Active",
          "editorMode": "code"
        }
      ]
    },
    {
      "id": 2,
      "title": "Deadlock Events",
      "type": "stat",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green" },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "traffic_coordinator_deadlocks",
          "legendFormat": "Deadlocks",
          "editorMode": "code"
        }
      ]
    },
    {
      "id": 3,
      "title": "Robot States",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue" },
              { "color": "green", "value": 1 },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "ERROR" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "DEGRADED" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "orange" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "IDLE" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "green" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "CHARGING" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "purple" } }
            ]
          }
        ]
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showUnfilled": true
      },
      "targets": [
        {
          "refId": "A",
          "expr": "count by (mode) (traffic_coordinator_robot_mode)",
          "legendFormat": "{{mode}}",
          "editorMode": "code"
        }
      ]
    },
    {
      "id": 4,
      "title": "Intersection Queue",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green" },
              { "color": "yellow", "value": 3 },
              { "color": "red", "value": 5 }
            ]
          },
          "custom": {
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "showLegend": true,
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "traffic_coordinator_intersection_queue",
          "legendFormat": "{{intersection}}",
          "editorMode": "code"
        }
      ]
    },
    {
      "id": 5,
      "title": "Safe Distance Holds",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green" },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 5 }
            ]
          },
          "custom": {
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "showLegend": true,
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(traffic_coordinator_speed_caps[5m])",
          "legendFormat": "Speed Caps",
          "editorMode": "code"
        }
      ]
    },
    {
      "id": 6,
      "title": "Battery / Charger State",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "red", "value": 10 }
            ]
          },
          "custom": {
            "align": "auto",
            "displayMode": "auto"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value #A" },
            "properties": [
              { "id": "displayName", "value": "Battery %" },
              { "id": "unit", "value": "percent" },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #B" },
            "properties": [
              { "id": "displayName", "value": "Charger Bay" },
              { "id": "custom.displayMode", "value": "color-text" },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "0": { "text": "Free", "color": "green" },
                      "1": { "text": "Occupied", "color": "red" }
                    }
                  }
                ]
              }
            ]
          }
        ]
      },
      "options": {
        "sortBy": [],
        "footer": { "show": false },
        "frameIndex": 0,
        "showTypeIcons": false
      },
      "targets": [
        {
          "refId": "A",
          "expr": "traffic_coordinator_battery_percent",
          "format": "table",
          "instant": true,
          "legendFormat": "{{robot}}",
          "editorMode": "code"
        },
        {
          "refId": "B",
          "expr": "traffic_coordinator_charger_occupancy",
          "format": "table",
          "instant": true,
          "legendFormat": "{{robot}}",
          "editorMode": "code"
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        }
      ]
    }
  ]
}
