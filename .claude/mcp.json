{
  "mcpServers": {
    "postgres": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@modelcontextprotocol/server-postgres", "postgresql://localhost:5432/ewm_db"],
      "disabled": true,
      "note": "Update PostgreSQL connection string"
    },
    "redis": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@modelcontextprotocol/server-redis", "redis://localhost:6379"],
      "disabled": true,
      "note": "Docker exec alt: docker exec robot-platform-redis redis-cli"
    },
    "fetch": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@modelcontextprotocol/server-fetch"]
    },
    "memory": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@modelcontextprotocol/server-memory"]
    },
    "filesystem": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@modelcontextprotocol/server-filesystem", "d:/EWM Robot/Robotic Platform Codes"]
    },
    "mqtt": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@nicepkg/mcp-server-mqtt"],
      "disabled": true,
      "note": "Alt: mosquitto_pub/sub via Bash"
    },
    "docker": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@modelcontextprotocol/server-docker"],
      "disabled": true,
      "note": "Alt: use Bash/PowerShell tool"
    },
    "brave-search": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@modelcontextprotocol/server-brave-search"],
      "disabled": true,
      "note": "Get API key at https://brave.com/search/api/"
    },
    "playwright": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@playwright/mcp"],
      "disabled": false
    }
  }
}
