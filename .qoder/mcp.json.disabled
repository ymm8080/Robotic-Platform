{
  "mcpServers": {
    "sqlite": {
      "command": "uvx",
      "args": ["mcp-server-sqlite", "--db-path", "./nodered-data/robot_platform.db"]
    },
    "redis": {
      "command": "uvx",
      "args": ["mcp-server-redis"]
    },
    "docker": {
      "command": "docker",
      "args": ["mcp", "server"]
    },
    "fetch": {
      "command": "uvx",
      "args": ["mcp-server-fetch"] 
    },
    "mqtt": {
      "command": "npx",
      "args": ["-y", "@nicepkg/mcp-server-mqtt"] 
    }
  }
}
